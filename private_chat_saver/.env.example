# Ключи вашего аккаунта (не бот-токен).
# Получите на https://my.telegram.org → API development tools
API_ID=
API_HASH=

# Имя файла сессии Telethon (создаётся локально при первом входе)
SESSION_NAME=private_saver

# Куда складывать медиа (относительно папки проекта)
MEDIA_DIR=media

# Максимальный размер скачиваемого файла, МБ (больше — пропускается, текст сохраняется)
MAX_FILE_MB=50

# Сохранять ли собственные исходящие сообщения (true/false)
SAVE_OUTGOING=true
